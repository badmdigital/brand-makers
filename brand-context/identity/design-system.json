{
  "meta": {
    "name": "[Brand Name]",
    "version": "1.0",
    "updated": "[YYYY-MM-DD]",
    "theme": "light"
  },

  "colors": {
    "primary": {
      "base": "",
      "50": "",
      "100": "",
      "200": "",
      "300": "",
      "400": "",
      "500": "",
      "600": "",
      "700": "",
      "800": "",
      "900": ""
    },
    "secondary": {
      "base": "",
      "50": "",
      "100": "",
      "200": "",
      "300": "",
      "400": "",
      "500": "",
      "600": "",
      "700": "",
      "800": "",
      "900": ""
    },
    "accent": {
      "base": "",
      "50": "",
      "100": "",
      "200": "",
      "300": "",
      "400": "",
      "500": "",
      "600": "",
      "700": "",
      "800": "",
      "900": ""
    },
    "neutral": {
      "base": "",
      "50": "",
      "100": "",
      "200": "",
      "300": "",
      "400": "",
      "500": "",
      "600": "",
      "700": "",
      "800": "",
      "900": ""
    },
    "semantic": {
      "success": "#22C55E",
      "warning": "#EAB308",
      "error": "#EF4444",
      "info": "#3B82F6"
    },
    "surface": {
      "light": {
        "background": "",
        "card": "",
        "border": "",
        "text": "",
        "textMuted": ""
      },
      "dark": {
        "background": "",
        "card": "",
        "border": "",
        "text": "",
        "textMuted": ""
      }
    }
  },

  "typography": {
    "fonts": {
      "heading": {
        "family": "",
        "fallback": "serif",
        "source": "google",
        "weights": [400, 600, 700]
      },
      "body": {
        "family": "",
        "fallback": "sans-serif",
        "source": "google",
        "weights": [400, 500, 600]
      },
      "mono": {
        "family": "",
        "fallback": "monospace",
        "source": "google",
        "weights": [400]
      }
    },
    "scale": {
      "display": {
        "size": "4rem",
        "lineHeight": "1.1",
        "weight": 700,
        "tracking": "-0.02em"
      },
      "h1": {
        "size": "3rem",
        "lineHeight": "1.15",
        "weight": 700,
        "tracking": "-0.02em"
      },
      "h2": {
        "size": "2.25rem",
        "lineHeight": "1.2",
        "weight": 600,
        "tracking": "-0.01em"
      },
      "h3": {
        "size": "1.75rem",
        "lineHeight": "1.3",
        "weight": 600,
        "tracking": "-0.01em"
      },
      "h4": {
        "size": "1.375rem",
        "lineHeight": "1.4",
        "weight": 600,
        "tracking": "0"
      },
      "bodyLg": {
        "size": "1.125rem",
        "lineHeight": "1.7",
        "weight": 400,
        "tracking": "0"
      },
      "body": {
        "size": "1rem",
        "lineHeight": "1.7",
        "weight": 400,
        "tracking": "0"
      },
      "bodySm": {
        "size": "0.875rem",
        "lineHeight": "1.6",
        "weight": 400,
        "tracking": "0"
      },
      "caption": {
        "size": "0.75rem",
        "lineHeight": "1.5",
        "weight": 400,
        "tracking": "0.02em"
      }
    }
  },

  "spacing": {
    "unit": "4px",
    "scale": {
      "xs": "4px",
      "sm": "8px",
      "md": "16px",
      "lg": "24px",
      "xl": "32px",
      "2xl": "48px",
      "3xl": "64px",
      "4xl": "96px"
    }
  },

  "borders": {
    "radius": {
      "sm": "4px",
      "md": "8px",
      "lg": "16px",
      "full": "9999px"
    },
    "width": {
      "thin": "1px",
      "base": "2px",
      "thick": "4px"
    }
  },

  "shadows": {
    "sm": "0 1px 2px rgba(0,0,0,0.05)",
    "md": "0 4px 12px rgba(0,0,0,0.08)",
    "lg": "0 8px 32px rgba(0,0,0,0.12)",
    "brand": ""
  },

  "breakpoints": {
    "sm": "640px",
    "md": "768px",
    "lg": "1024px",
    "xl": "1280px"
  },

  "components": {
    "button": {
      "primary": {
        "background": "colors.primary.base",
        "color": "colors.surface.light.background",
        "borderRadius": "borders.radius.md",
        "paddingX": "spacing.scale.lg",
        "paddingY": "spacing.scale.sm",
        "font": "typography.fonts.body",
        "fontWeight": 600,
        "fontSize": "typography.scale.body.size"
      },
      "secondary": {
        "background": "transparent",
        "color": "colors.primary.base",
        "border": "borders.width.base solid colors.primary.base",
        "borderRadius": "borders.radius.md",
        "paddingX": "spacing.scale.lg",
        "paddingY": "spacing.scale.sm",
        "font": "typography.fonts.body",
        "fontWeight": 600,
        "fontSize": "typography.scale.body.size"
      },
      "ghost": {
        "background": "transparent",
        "color": "colors.primary.base",
        "borderRadius": "borders.radius.md",
        "paddingX": "spacing.scale.md",
        "paddingY": "spacing.scale.sm",
        "font": "typography.fonts.body",
        "fontWeight": 500,
        "fontSize": "typography.scale.body.size"
      }
    },
    "input": {
      "background": "colors.surface.light.card",
      "border": "borders.width.thin solid colors.surface.light.border",
      "borderRadius": "borders.radius.md",
      "paddingX": "spacing.scale.md",
      "paddingY": "spacing.scale.sm",
      "font": "typography.fonts.body",
      "fontSize": "typography.scale.body.size",
      "focusBorder": "colors.primary.base"
    },
    "card": {
      "background": "colors.surface.light.card",
      "border": "borders.width.thin solid colors.surface.light.border",
      "borderRadius": "borders.radius.lg",
      "padding": "spacing.scale.lg",
      "shadow": "shadows.sm"
    }
  },

  "icons": {
    "library": "lucide",
    "defaultSize": "20px",
    "strokeWidth": "1.5"
  },

  "layout": {
    "maxWidth": "1200px",
    "sectionPadding": {
      "y": "spacing.scale.4xl",
      "x": "spacing.scale.xl"
    },
    "containerPadding": {
      "default": "spacing.scale.xl",
      "mobile": "spacing.scale.md"
    }
  },

  "animation": {
    "duration": "200ms",
    "easing": "ease-in-out",
    "hoverScale": "1.02"
  }
}
